<?xml version="1.0" encoding="UTF-8"?>
<!-- TiiBnTick — Invoice Template -->
<!-- Author: MANFOUO Braun -->
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN"
        "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="invoice"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20"
              uuid="c3d4e5f6-a7b8-9012-cdef-123456789012">

    <parameter name="invoiceNumber" class="java.lang.String"/>
    <parameter name="invoiceDate" class="java.lang.String"/>
    <parameter name="tenantName" class="java.lang.String"/>
    <parameter name="clientName" class="java.lang.String"/>
    <parameter name="clientAddress" class="java.lang.String"/>
    <parameter name="trackingCode" class="java.lang.String"/>
    <parameter name="serviceLine" class="java.lang.String"/>
    <parameter name="amountHT" class="java.lang.String"/>
    <parameter name="tvaRate" class="java.lang.String"/>
    <parameter name="tvaAmount" class="java.lang.String"/>
    <parameter name="totalTTC" class="java.lang.String"/>
    <parameter name="currency" class="java.lang.String"/>
    <parameter name="paymentMethod" class="java.lang.String"/>

    <queryString><![CDATA[]]></queryString>

    <title>
        <band height="100">
            <staticText>
                <reportElement x="0" y="0" width="555" height="30"/>
                <textElement textAlignment="Center">
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[FACTURE]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="35" width="277" height="20"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["Émetteur: " + $P{tenantName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="278" y="35" width="277" height="20"/>
                <textElement textAlignment="Right"><font size="10"/></textElement>
                <textFieldExpression><![CDATA["N° " + $P{invoiceNumber}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="278" y="55" width="277" height="20"/>
                <textElement textAlignment="Right"><font size="10"/></textElement>
                <textFieldExpression><![CDATA["Date: " + $P{invoiceDate}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="85" width="555" height="1"/>
            </line>
        </band>
    </title>

    <summary>
        <band height="500">
            <!-- Client info -->
            <staticText>
                <reportElement x="0" y="10" width="555" height="16"/>
                <textElement><font isBold="true" size="9"/></textElement>
                <text><![CDATA[FACTURÉ À:]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="28" width="400" height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{clientName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="46" width="400" height="30"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{clientAddress}]]></textFieldExpression>
            </textField>

            <!-- Detail line -->
            <staticText>
                <reportElement x="0" y="100" width="355" height="16" backcolor="#EEEEEE"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Description]]></text>
            </staticText>
            <staticText>
                <reportElement x="355" y="100" width="200" height="16" backcolor="#EEEEEE"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Right"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Montant HT]]></text>
            </staticText>

            <textField>
                <reportElement x="0" y="118" width="355" height="30"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{serviceLine} + " — Code: " + $P{trackingCode}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="355" y="118" width="200" height="30"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{amountHT} + " " + $P{currency}]]></textFieldExpression>
            </textField>

            <!-- Totals -->
            <staticText>
                <reportElement x="300" y="165" width="155" height="18"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <text><![CDATA[Sous-total HT:]]></text>
            </staticText>
            <textField>
                <reportElement x="455" y="165" width="100" height="18"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{amountHT} + " " + $P{currency}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="300" y="183" width="155" height="18"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <text><![CDATA[TVA:]]></text>
            </staticText>
            <textField>
                <reportElement x="455" y="183" width="100" height="18"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{tvaAmount} + " " + $P{currency} + " (" + $P{tvaRate} + ")"]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="300" y="205" width="155" height="22" backcolor="#222222"/>
                <textElement textAlignment="Right"><font size="10" isBold="true" foreColor="#FFFFFF"/></textElement>
                <text><![CDATA[TOTAL TTC:]]></text>
            </staticText>
            <textField>
                <reportElement x="455" y="205" width="100" height="22" backcolor="#222222"/>
                <textElement textAlignment="Right"><font size="10" isBold="true" foreColor="#FFFFFF"/></textElement>
                <textFieldExpression><![CDATA[$P{totalTTC} + " " + $P{currency}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="240" width="200" height="18"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Mode de paiement:]]></text>
            </staticText>
            <textField>
                <reportElement x="200" y="240" width="355" height="18"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{paymentMethod}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="430" width="555" height="40" forecolor="#888888"/>
                <textElement textAlignment="Center"><font size="7"/></textElement>
                <text><![CDATA[TiiBnTick — Logistique de confiance pour l'Afrique centrale et au-delà.
Ce document tient lieu de facture légale conformément aux dispositions en vigueur.]]></text>
            </staticText>
        </band>
    </summary>
</jasperReport>
