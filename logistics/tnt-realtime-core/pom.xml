<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <!-- =========================================================
         PARENT — TiiBnTick Core Parent POM
         ========================================================= -->
    <parent>
        <groupId>com.yowyob.tiibntick.core</groupId>
        <artifactId>tiibntick-core-parent</artifactId>
        <version>0.0.1</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <!-- =========================================================
         MODULE IDENTITY
         Author: MANFOUO Braun
         Layer : L3 — Logistics
         Role  : Real-time engine — WebSocket STOMP multi-tenant,
                 GPS stream ingestion, live ETA broadcast,
                 presence management, geofencing
         ========================================================= -->
    <artifactId>tnt-realtime-core</artifactId>
    <packaging>jar</packaging>

    <name>TiiBnTick Core — tnt-realtime-core</name>
    <description>
        Real-time engine shared across all TiiBnTick platforms.
        Provides WebSocket STOMP multi-tenant hub, SSE for lightweight clients,
        GPS stream ingestion (10-30s interval), Presence Manager (Redis TTL),
        Live ETA broadcast (Kalman updates), and Geofence monitoring.
        Reactive WebFlux throughout, Redis-backed for multi-instance scaling.
    </description>

    <!-- =========================================================
         DEPENDENCIES
         ========================================================= -->
    <dependencies>
        <!-- ── tnt-auth-core (Foundation L1 — security context, @CurrentUser) ── -->
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-auth-core</artifactId>
        </dependency>

        <!-- ── TiiBnTick Core Internal Modules (L2 Identity) ── -->
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-actor-core</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- ── TiiBnTick Core Internal Modules (L3 Logistics) ── -->
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-geo-core</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-route-core</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- ── TiiBnTick Foundation L0 ── -->
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>yow-event-kernel</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-common-core</artifactId>
        </dependency>

        <!-- ── Spring Boot WebFlux (Reactive Web) ── -->
