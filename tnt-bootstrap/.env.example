# TiiBnTick Core — local dev environment
#
# Usage: cp .env.example .env   (docker compose auto-loads ./.env from this directory)
# `.env` is gitignored — this file holds safe, non-secret defaults for local dev only.
# For staging/prod, see .env.prod.example instead (different provisioning model).

# ── Database (local docker-compose Postgres container) ─────────────────────
DB_NAME=tiibntick_core
DB_USER=tiibntick
DB_PASSWORD=tiibntick_pass
DB_PORT=5433
DB_SSL_MODE=disable
DB_POOL_INITIAL_SIZE=2
DB_POOL_MAX_SIZE=10
DB_POOL_MAX_IDLE_MINUTES=30
# Only needed if RT-comops (Kernel) runs against a different DB than TiiBnTick's
# own in your local setup; defaults to the same container/database otherwise.
KERNEL_DB_HOST=postgres
KERNEL_DB_NAME=tiibntick_core

# ── Object storage (local MinIO container) ──────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# ── Observability dashboards ─────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=tiibntick_grafana

# ── JWT / Kernel auth bridge (dev auto-generates an in-memory RSA key pair) ─
JWT_ISSUER_URI=http://localhost:9000
JWT_AUTO_GENERATE_KEY_PAIR=true
JWT_KEY_ID=tnt-core-key-dev

# ── tnt-auth-core / tnt-roles-core ──────────────────────────────────────────
TNT_AUTH_SERVICE_CODE=TNT_AGENCY
TNT_AUTH_ACTOR_RESOLUTION=true
TNT_AUTH_ALLOW_ANONYMOUS=false
TNT_SYSTEM_TENANT_ID=00000000-0000-0000-0000-000000000001
TNT_ROLES_PROVISION_ON_STARTUP=true
TNT_ROLES_AOP_ENABLED=true
TNT_ROLES_CACHE_TTL=300

# ── Platform → Core gateway (CORE_KERNEL_GATEWAY_SPEC.md) ───────────────────
# Local-dev-only credentials for platform backends (Agency, Go, ...) calling
# this Core instance — safe to leave as-is for local testing, but generate real
# random values (openssl rand -base64 32) for staging/prod, see .env.prod.example.
# Leave a pair blank to disable that platform.
TNT_AGENCY_CLIENT_ID=tnt-agency-dev
TNT_AGENCY_API_KEY=dev-agency-api-key-change-in-staging-and-prod
TNT_GO_CLIENT_ID=tnt-go-dev
TNT_GO_API_KEY=dev-go-api-key-change-in-staging-and-prod
TNT_LINK_CLIENT_ID=
TNT_LINK_API_KEY=
TNT_MARKET_CLIENT_ID=
TNT_MARKET_API_KEY=
TNT_POINT_RELAIS_CLIENT_ID=
TNT_POINT_RELAIS_API_KEY=

# ── Misc ─────────────────────────────────────────────────────────────────────
QR_HMAC_SECRET=dev-hmac-secret-change-in-staging-and-prod
SWAGGER_SERVER_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── App container profile ───────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
