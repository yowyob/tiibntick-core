# TiiBnTick Core — production environment TEMPLATE
#
# This is documentation, not a file to `cp` and fill in: it must NEVER be
# committed with real values. In staging/prod, TiiBnTick runs on the shared
# Yowyob PostgreSQL instance (one database per product, not a dedicated
# server) — actual secrets are owned by the Yowyob infra team and injected via
# your deployment platform's secret manager (GitLab CI/CD protected+masked
# variables, Kubernetes Secret, Vault, etc.), never via a plaintext .env file
# on disk in prod.
#
# Before first deploy, coordinate with the Yowyob DBA team so they provision
# (see tnt-bootstrap/docker/postgres/init.sql for the full rationale):
#   - a dedicated database for TiiBnTick on the shared instance (name below
#     is a placeholder — confirm the final name to avoid collisions with
#     other Yowyob products on the same instance)
#   - an application role scoped to that database only (not superuser)
#   - the postgis / postgis_topology / uuid-ossp / pg_trgm extensions
#     installed once on that database (extension creation needs superuser,
#     which this app's role will not have)
#   - RT-comops (Kernel)'s own database coordinates, if different from
#     TiiBnTick's — KERNEL_DB_HOST/KERNEL_DB_NAME default to TiiBnTick's own
#     DB otherwise, which is only correct in local monolith dev.

SPRING_PROFILES_ACTIVE=prod

# ── Database — values from the Yowyob DBA team, injected via secret manager ─
DB_HOST=CHANGE_ME_shared_postgres_host.yowyob.internal
DB_PORT=5432
DB_NAME=CHANGE_ME_tiibntick_core_prod
DB_USER=CHANGE_ME_tiibntick_prod_role
DB_PASSWORD=CHANGE_ME_use_secret_manager
# Shared instance enforces TLS — do not deploy with "disable" outside local dev.
DB_SSL_MODE=verify-full
# 8 ConnectionFactory beans (kernel + core + 6 platforms) share this instance in
# monolith mode — size DB_POOL_MAX_SIZE against the max_connections quota the
# DBA team grants this app (effective ceiling is roughly DB_POOL_MAX_SIZE x 8),
# not against the whole server's max_connections.
DB_POOL_INITIAL_SIZE=2
DB_POOL_MAX_SIZE=10
DB_POOL_MAX_IDLE_MINUTES=30

# RT-comops (Kernel) database — MUST be set explicitly; do not rely on the
# default (which points at TiiBnTick's own DB_HOST/DB_NAME).
KERNEL_DB_HOST=CHANGE_ME_kernel_postgres_host.yowyob.internal
KERNEL_DB_NAME=CHANGE_ME_kernel_db_name

# ── Object storage ───────────────────────────────────────────────────────────
MINIO_ENDPOINT=https://CHANGE_ME_minio.yowyob.internal
MINIO_ACCESS_KEY=CHANGE_ME_use_secret_manager
MINIO_SECRET_KEY=CHANGE_ME_use_secret_manager
MINIO_PUBLIC_ENDPOINT=https://CHANGE_ME_public_minio_url

# ── Messaging / cache ────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=CHANGE_ME_kafka_bootstrap:9092
REDIS_HOST=CHANGE_ME_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_use_secret_manager

# ── JWT / Kernel auth bridge ─────────────────────────────────────────────────
# Production: RSA key loaded from a mounted secret, never auto-generated.
JWT_AUTO_GENERATE_KEY_PAIR=false
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key.pem
JWT_KEY_ID=tnt-core-key-prod
JWT_ISSUER_URI=https://auth.tiibntick.com

# ── tnt-auth-core / tnt-roles-core ──────────────────────────────────────────
TNT_AUTH_SERVICE_CODE=TNT_AGENCY
TNT_SYSTEM_TENANT_ID=00000000-0000-0000-0000-000000000001

# ── Kernel bridge (RT-comops HTTP API) ───────────────────────────────────────
TNT_KERNEL_BASE_URL=https://kernel-core.yowyob.com/kernel-api
TNT_KERNEL_API_KEY=CHANGE_ME_use_secret_manager
TNT_KERNEL_CLIENT_ID=CHANGE_ME_registered_client_id

# ── Platform → Core gateway (CORE_KERNEL_GATEWAY_SPEC.md) ───────────────────
# One X-Client-Id / X-Api-Key pair PER platform backend — distinct from
# TNT_KERNEL_* above (that one is Core's own identity toward the Kernel; these
# are what each platform presents to Core). Generate each API key with:
#   openssl rand -base64 32
# Leave a pair blank to disable that platform (PlatformClientRegistry skips
# unconfigured entries at startup rather than erroring). Hand the client-id +
# api-key to the corresponding platform team via your secret manager — never
# by email/Slack — for them to set as their own TNT_CORE_BASE_URL +
# TNT_<PLATFORM>_CLIENT_ID/API_KEY (see CORE_KERNEL_GATEWAY_SPEC.md §12.1).
TNT_AGENCY_CLIENT_ID=CHANGE_ME_tnt-agency-prod
TNT_AGENCY_API_KEY=CHANGE_ME_use_secret_manager
TNT_GO_CLIENT_ID=CHANGE_ME_tnt-go-prod
TNT_GO_API_KEY=CHANGE_ME_use_secret_manager
TNT_LINK_CLIENT_ID=CHANGE_ME_tnt-link-prod
TNT_LINK_API_KEY=CHANGE_ME_use_secret_manager
TNT_MARKET_CLIENT_ID=CHANGE_ME_tnt-market-prod
TNT_MARKET_API_KEY=CHANGE_ME_use_secret_manager
TNT_POINT_RELAIS_CLIENT_ID=CHANGE_ME_tnt-point-relais-prod
TNT_POINT_RELAIS_API_KEY=CHANGE_ME_use_secret_manager

# ── Misc ─────────────────────────────────────────────────────────────────────
QR_HMAC_SECRET=CHANGE_ME_strong_random_256bit_value
SWAGGER_SERVER_URL=https://api.tiibntick.com
CORS_ALLOWED_ORIGINS=https://app.tiibntick.com
