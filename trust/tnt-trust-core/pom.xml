<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.yowyob.tiibntick.core</groupId>
        <artifactId>tiibntick-core-parent</artifactId>
        <version>0.0.1</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <artifactId>tnt-trust-core</artifactId>
    <packaging>jar</packaging>
    <name>TiiBnTick Core — tnt-trust-core</name>
    <description>
        L3 Logistics — Trust module: DeliveryProof (Fil d'Ariane) anchoring, CustodyTransfer chain,
        DID issuance for deliverers, Proof-of-Location (PoL), Reputation Badges, DAO Zone Rules,
        BillingPolicy anchoring, and Incident blockchain chain management (IBlockchainAuditPort).
        Communicates outward via Kafka (publish to yow.trust.events) and REST WebClient
        (query the yow-trust-event Kernel microservice).
        Author: MANFOUO Braun — ENSP Yaoundé 2026.
    </description>

    <!-- ═══════════════════════════════════════════════════════════
         DEPENDENCIES
         ═══════════════════════════════════════════════════════════ -->
    <dependencies>

        <!-- ── tnt-auth-core: @CurrentUser in controllers ── -->
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-auth-core</artifactId>
        </dependency>
        <!-- ── tnt-actor-core: implements IBadgeAnchorPort (one-directional, compliant layering —
             actor-core is L2 identity, trust is L6 (trust/, transversal); trust depending down
             into a lower layer is the normal direction, actor-core must never depend back on trust) ── -->
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-actor-core</artifactId>
        </dependency>
        <!-- ── tnt-roles-core: @RequirePermission AOP guards ── -->
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-roles-core</artifactId>
        </dependency>
        <!-- ── tnt-delivery-core: implements DeliveryProofAnchorPort (one-directional —
             delivery does not depend back on trust, no cycle) ── -->
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-delivery-core</artifactId>
        </dependency>
        <!-- ── tnt-incident-core: implements IBlockchainAuditPort (one-directional —
             incident does not depend back on trust, no cycle) ── -->
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-incident-core</artifactId>
        </dependency>
        <!-- ── tnt-billing-pricing: implements BillingPolicyAnchorPort (one-directional —
             billing-pricing does not depend back on trust, no cycle) ── -->
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-billing-pricing</artifactId>
        </dependency>
        <!-- ── tnt-billing-wallet: implements IPaymentAnchorPort (one-directional —
             billing-wallet does not depend back on trust, no cycle) ── -->
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-billing-wallet</artifactId>
        </dependency>
        <!-- ── tnt-dispute-core: implements IBlockchainProofPort (one-directional —
             dispute does not depend back on trust, no cycle) ── -->
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-dispute-core</artifactId>
        </dependency>
        <!-- ── tnt-realtime-core: implements IGeofenceAnchorPort (one-directional —
             realtime does not depend back on trust, no cycle) ── -->
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-realtime-core</artifactId>
        </dependency>
        <!-- ── tnt-organization-core: implements FreelancerOrgDidAnchorPort (one-directional —
             organization does not depend back on trust, no cycle) ── -->
        <dependency>
            <groupId>com.yowyob.tiibntick.core</groupId>
            <artifactId>tnt-organization-core</artifactId>
        </dependency>

        <!-- ── Spring WebFlux + R2DBC ── -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-webflux</artifactId>
        </dependency>
        <!-- AOP for @RequirePermission (tnt-roles-core) -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-aop</artifactId>
        </dependency>
        <!-- Security for @CurrentUser context (tnt-auth-core) -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-security</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-r2dbc</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-autoconfigure</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-configuration-processor</artifactId>
            <optional>true</optional>
        </dependency>

        <!-- ── Kafka (producer toward yow.trust.events, consumer of yow.trust.events.committed) ── -->
        <dependency>
            <groupId>org.springframework.kafka</groupId>
            <artifactId>spring-kafka</artifactId>
        </dependency>

        <!-- ── Jackson ── -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.datatype</groupId>
            <artifactId>jackson-datatype-jsr310</artifactId>
        </dependency>

        <!-- ── Lombok ── -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- ── API Documentation ── -->
        <dependency>
            <groupId>org.springdoc</groupId>
            <artifactId>springdoc-openapi-starter-webflux-ui</artifactId>
        </dependency>

        <!-- ── Observability ── -->
        <dependency>
            <groupId>io.micrometer</groupId>
            <artifactId>micrometer-core</artifactId>
        </dependency>

        <!-- ── Actuator: ReactiveHealthIndicator for the trustEventGateway health group ── -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>

        <!-- ── Resilience4j: circuit breaker / retry / time limiter around yow-trust-event ──
             resilience4j-reactor is required for CircuitBreakerOperator/TimeLimiterOperator
             to correctly decorate the Mono/Flux returned by @CircuitBreaker/@TimeLimiter
             methods — without it the annotations silently no-op in WebFlux. -->
        <!-- spring-boot4 (not spring-boot3): this app runs on Boot 4's new health package
             (org.springframework.boot.health.contributor, see TrustEventHealthIndicator) —
             resilience4j-spring-boot3's CircuitBreakersHealthIndicatorAutoConfiguration
             targets the old Boot3 actuate.health package and would fail to load here. -->
        <dependency>
            <groupId>io.github.resilience4j</groupId>
            <artifactId>resilience4j-spring-boot4</artifactId>
        </dependency>
        <dependency>
            <groupId>io.github.resilience4j</groupId>
            <artifactId>resilience4j-reactor</artifactId>
        </dependency>
        <!-- resilience4j-spring6's RxJava3FallbackDecorator references RxJava3 types in its
             method signatures — Spring's @ConditionalOnMissingBean type deduction reflectively
             loads that class regardless of whether the app ever uses RxJava, so this must be
             on the classpath or context refresh fails with NoClassDefFoundError. Runtime-only:
             TiiBnTick code never references RxJava directly. -->
        <dependency>
            <groupId>io.reactivex.rxjava3</groupId>
            <artifactId>rxjava</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!-- ── PostgreSQL R2DBC driver ── -->
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>r2dbc-postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>org.liquibase</groupId>
            <artifactId>liquibase-core</artifactId>
        </dependency>

        <!-- ── Test ── -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>io.projectreactor</groupId>
            <artifactId>reactor-test</artifactId>
            <version>${reactor-test.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <scope>test</scope>
        </dependency>
        <!-- Stubs the yow-trust-event REST API in TrustEventRestClientAdapterTest -->
        <dependency>
            <groupId>org.wiremock</groupId>
            <artifactId>wiremock-standalone</artifactId>
            <version>3.9.2</version>
            <scope>test</scope>
        </dependency>

    </dependencies>

</project>
